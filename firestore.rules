
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/wallet/{walletDoc} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow update: if isSignedIn(); 
      allow create: if isOwner(userId);
    }

    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isSignedIn(); 
    }

    match /users/{userId}/investments/{investmentId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin();
    }

    match /investment_plans/{planId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /depositRequests/{depositRequestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /withdrawRequests/{requestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(adminId);
    }

    match /system/{document=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
