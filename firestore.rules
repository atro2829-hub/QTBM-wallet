rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * QTBM WALLET SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict ownership model for user-specific data and a
     * Database-Based Access Control (DBAC) model for administrative functions.
     * It prioritizes Authorization Independence to minimize cross-document lookups.
     *
     * DATA STRUCTURE:
     * - User-owned data is nested under /users/{userId} (Profile, Wallet, Transactions).
     * - Global entities (Products, Offers) are top-level and readable by all users.
     * - Admin privileges are determined by the existence of a document in /roles_admin/{uid}.
     * - Deposit Requests are top-level but utilize denormalized userId fields for owner access.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID exists in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the provided UID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for destructive operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /users/{userId}/wallet/{walletDoc} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && (isAdmin() || request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }

    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.initiatorUserId == userId;
      allow update, delete: if false;
    }

    match /depositRequests/{depositRequestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); 
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /offers/{offerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      // Allow user to check their own admin status or admins to manage all
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      // Allow self-registration during account creation as requested
      allow create: if isOwner(adminId);
      allow update, delete: if isAdmin();
    }
  }
}