rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * QTBM WALLET SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict ownership model for user-specific data and a
     * Database-Based Access Control (DBAC) model for administrative functions.
     *
     * DATA STRUCTURE:
     * - User-owned data is nested under /users/{userId} (Profile, Wallet, Transactions).
     * - Global entities (Products) are top-level and readable by all users.
     * - Admin privileges are determined by the existence of a document in /roles_admin/{uid}.
     * - System configuration is stored in /system/config.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID exists in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the provided UID matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      // Prevent updating sensitive fields once they are set (Enforcing "cannot change later")
      allow update: if isOwner(userId) && (
        !('fullName' in resource.data) || request.resource.data.fullName == resource.data.fullName
      );
      allow delete: if isAdmin();
    }

    match /users/{userId}/wallet/{walletDoc} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    match /depositRequests/{depositRequestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      // Allow self-registration as admin for the initial prototype as requested
      allow create: if isOwner(adminId);
      allow update, delete: if isAdmin();
    }

    match /system/{document=**} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /support_chats/{chatId} {
      allow get, list: if isAdmin() || isOwner(chatId);
      allow create: if isOwner(chatId);
      allow update: if isAdmin() || isOwner(chatId);
      allow delete: if isAdmin();
    }

    match /support_chats/{chatId}/messages/{messageId} {
      allow get, list: if isAdmin() || isOwner(chatId);
      allow create: if isAdmin() || isOwner(chatId);
      allow update, delete: if isAdmin();
    }
  }
}