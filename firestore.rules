
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * QTBM WALLET SECURITY RULES - FINALIZED FOR DEPLOYMENT
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      // Lock legal information once set
      allow update: if isOwner(userId) && (
        !('fullName' in resource.data) || request.resource.data.fullName == resource.data.fullName
      );
      allow delete: if isAdmin();
    }

    match /users/{userId}/wallet/{walletDoc} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    match /depositRequests/{depositRequestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(adminId);
      allow update, delete: if isAdmin();
    }

    // Allow public access to system config for login page information
    match /system/{document=**} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /support_chats/{chatId} {
      allow get, list: if isAdmin() || isOwner(chatId);
      allow create: if isOwner(chatId);
      allow update: if isAdmin() || isOwner(chatId);
      allow delete: if isAdmin();
    }

    match /support_chats/{chatId}/messages/{messageId} {
      allow get, list: if isAdmin() || isOwner(chatId);
      allow create: if isAdmin() || isOwner(chatId);
      allow update, delete: if isAdmin();
    }
  }
}
