
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the QTBM Wallet application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "nationalIdNumber": { "type": "string" },
        "role": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "yerBalance": { "type": "number" },
        "usdBalance": { "type": "number" },
        "sarBalance": { "type": "number" },
        "goldBalance": { "type": "number", "description": "Gold balance in grams" }
      }
    },
    "InvestmentPlan": {
      "title": "InvestmentPlan",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "minAmount": { "type": "number" },
        "durationDays": { "type": "number" },
        "interestRate": { "type": "number" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "UserInvestment": {
      "title": "UserInvestment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "expectedReturn": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/wallet/wallet": {
      "schema": { "$ref": "#/backend/entities/Wallet" },
      "description": "User balances."
    },
    "/investment_plans/{planId}": {
      "schema": { "$ref": "#/backend/entities/InvestmentPlan" },
      "description": "Available investment plans."
    },
    "/users/{userId}/investments/{investmentId}": {
      "schema": { "$ref": "#/backend/entities/UserInvestment" },
      "description": "User active and past investments."
    }
  }
}
