
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the QTBM Wallet application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "nationalIdNumber": { "type": "string" },
        "role": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "yerBalance": { "type": "number" },
        "usdBalance": { "type": "number" },
        "sarBalance": { "type": "number" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "iconName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "type": "object",
      "properties": {
        "contactPhone": { "type": "string" },
        "contactEmail": { "type": "string" },
        "usdToYerRate": { "type": "number" },
        "usdToSarRate": { "type": "number" },
        "usdtCommission": { "type": "number", "description": "Percentage commission for USDT purchase (e.g. 0.05 for 5%)" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/wallet/wallet": {
      "schema": { "$ref": "#/backend/entities/Wallet" },
      "description": "User balances."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "System products."
    },
    "/system/config": {
      "schema": { "$ref": "#/backend/entities/SystemConfig" },
      "description": "Global system configuration and rates."
    }
  }
}
