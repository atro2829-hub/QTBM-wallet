
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the QTBM Wallet application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "nationalIdNumber": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "yerBalance": { "type": "number" },
        "usdBalance": { "type": "number" },
        "sarBalance": { "type": "number" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "iconName": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "WithdrawRequest": {
      "title": "WithdrawRequest",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "method": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/wallet/wallet": {
      "schema": { "$ref": "#/backend/entities/Wallet" },
      "description": "User balances."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "System products."
    },
    "/withdrawRequests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/WithdrawRequest" },
      "description": "User withdrawal requests."
    }
  }
}
