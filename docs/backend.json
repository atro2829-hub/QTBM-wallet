
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the QTBM Wallet application, storing profile information and settings.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The full legal name of the user."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "address": {
          "type": "string",
          "description": "The user's residential address."
        },
        "city": {
          "type": "string",
          "description": "The user's city of residence."
        },
        "nationalIdNumber": {
          "type": "string",
          "description": "The user's national identification number."
        },
        "preferredTheme": {
          "type": "string",
          "description": "The user's preferred application theme (light or dark mode)."
        },
        "preferredLanguage": {
          "type": "string",
          "description": "The user's preferred display language (English or Arabic)."
        },
        "role": {
          "type": "string",
          "description": "The user's role (e.g., 'user' or 'admin')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "phoneNumber",
        "address",
        "city",
        "nationalIdNumber",
        "preferredTheme",
        "preferredLanguage",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Wallet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Wallet",
      "type": "object",
      "description": "Stores the multi-currency balances for a specific user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "yerBalance": {
          "type": "number"
        },
        "usdBalance": {
          "type": "number"
        },
        "sarBalance": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "yerBalance",
        "usdBalance",
        "sarBalance",
        "createdAt",
        "updatedAt"
      ]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "initiatorUserId": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "initiatorUserId",
        "type",
        "currency",
        "amount",
        "description",
        "status",
        "createdAt"
      ]
    },
    "DepositRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DepositRequest",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "externalTransactionDetails": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "submissionDate": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "currency",
        "amount",
        "externalTransactionDetails",
        "status",
        "submissionDate"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        },
        "iconName": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "price",
        "currency",
        "isActive",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profile data."
        }
      },
      {
        "path": "/users/{userId}/wallet/wallet",
        "definition": {
          "entityName": "Wallet",
          "schema": {
            "$ref": "#/backend/entities/Wallet"
          },
          "description": "User multi-currency balances."
        }
      },
      {
        "path": "/users/{userId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": {
            "$ref": "#/backend/entities/Transaction"
          },
          "description": "User transaction history."
        }
      },
      {
        "path": "/depositRequests/{depositRequestId}",
        "definition": {
          "entityName": "DepositRequest",
          "schema": {
            "$ref": "#/backend/entities/DepositRequest"
          },
          "description": "Pending deposit requests."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Available products and services."
        }
      },
      {
        "path": "/roles_admin/{adminId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Admin privileges indicator."
        }
      }
    ]
  }
}
